# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# ── LLM Model ────────────────────────────────────────────────────────────────
# Which model to use. Provider is inferred from the name (OpenAI by default).
# Leave blank to use the built-in default: gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# To use Qwen via DashScope's OpenAI-compatible endpoint, set:
#   LLM_MODEL=qwen-plus
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# and fill in DASHSCOPE_API_KEY below. OPENAI_API_KEY is not required in that case.
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── API Keys ──────────────────────────────────────────────────────────────────
# OpenAI (required when LLM_MODEL is an OpenAI model)
OPENAI_API_KEY=your-openai-api-key-here

# DashScope / Alibaba Cloud (required when LLM_BASE_URL points to DashScope)
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Anthropic (optional, for Claude models)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Tavily search (required for research agent example)
TAVILY_API_KEY=your-tavily-api-key-here

# ── Langfuse Tracing (optional) ───────────────────────────────────────────────
# Local Langfuse instance (default port 3000).
# Remove or leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000
