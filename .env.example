# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# ── LLM Model ────────────────────────────────────────────────────────────────
# Which model to use. Leave blank to use the built-in default (gpt-4o-mini).
LLM_MODEL=gpt-4o-mini

# ── Option A: OpenAI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Option B: Qwen via DashScope (langchain-qwq) ─────────────────────────────
# Set DASHSCOPE_API_KEY and change LLM_MODEL to a Qwen model.
# No LLM_BASE_URL needed — langchain-qwq connects natively.
# Available models: qwen-plus, qwen-max, qwen-turbo, qwen3-32b, qwq-32b …
#
# LLM_MODEL=qwen-plus
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ── Option C: any OpenAI-compatible endpoint ──────────────────────────────────
# LLM_MODEL=your-model-name
# LLM_BASE_URL=https://your-endpoint/v1
# OPENAI_API_KEY=your-key-here

# ── Other API Keys ────────────────────────────────────────────────────────────
# Anthropic (for Claude models via init_chat_model)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Tavily search (required for research agent example)
TAVILY_API_KEY=your-tavily-api-key-here

# ── Langfuse Tracing (optional) ───────────────────────────────────────────────
# Local Langfuse instance (default port 3000). Remove to disable tracing.
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000
